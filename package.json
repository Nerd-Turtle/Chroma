{
  "name": "chroma",
  "version": "0.1.0",
  "description": "Chroma Server Manager is a Minecraft Bedrock Dedicated Server and addon manager.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 src/web",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:web": "vite build src/web",
    "preview:web": "vite preview --host 127.0.0.1"
  },
  "keywords": [
    "minecraft",
    "bedrock",
    "server",
    "addons",
    "curseforge"
  ],
  "author": "Nerd Turtle",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^3.3.0",
    "@types/yazl": "^3.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "lucide-react": "^0.542.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  }
}
